{
  "annotations": {"list": []},
  "description": "보안 알람 현황 - 봇 차단, WAF 차단, Rate Limit, 인증 실패",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 1, "title": "차단 현황 요약", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1}, "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(increase(authz_adapter_check_requests_total{action=\"block\"}[5m])) or vector(0)", "refId": "A"}],
      "title": "ext_authz 차단 (5m)", "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1}, "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(increase(istio_requests_total{reporter=\"destination\", response_code=\"403\"}[5m])) or vector(0)", "refId": "A"}],
      "title": "Istio 403 (5m)", "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1}, "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(increase(istio_requests_total{reporter=\"destination\", response_code=\"429\"}[5m])) or vector(0)", "refId": "A"}],
      "title": "Rate Limited 429 (5m)", "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "전체 차단 중 캐시 히트 비율",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "max": 100, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "percent"}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1}, "id": 5,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": false},
      "targets": [{"expr": "100 * sum(increase(authz_adapter_check_requests_total{reason=\"blacklist\", action=\"block\"}[5m])) / (sum(increase(authz_adapter_check_requests_total{action=\"block\"}[5m])) + 0.001) or vector(0)", "refId": "A"}],
      "title": "캐시 히트 비율", "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 30, "lineWidth": 2, "showPoints": "never", "stacking": {"mode": "none"}}, "unit": "reqps"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5}, "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum(rate(authz_adapter_check_requests_total{reason=\"blacklist\", action=\"block\"}[5m])) or vector(0)", "legendFormat": "Blacklist (캐시)", "refId": "A"},
        {"expr": "sum(rate(authz_adapter_check_requests_total{reason=\"bot_token\", action=\"block\"}[5m])) or vector(0)", "legendFormat": "X-Bot-Token", "refId": "B"},
        {"expr": "sum(rate(authz_adapter_check_requests_total{reason=~\"bot_fingerprint.*\", action=\"block\"}[5m])) or vector(0)", "legendFormat": "Fingerprint", "refId": "C"},
        {"expr": "sum(rate(authz_adapter_check_requests_total{reason=~\"QUEUE_ENTER|SEAT_ENTRY|RECOMMENDATION_BLOCKS|SECTION_BLOCKS|ASSIGN_HOLD|SEAT_HOLDS\", action=\"block\"}[5m])) or vector(0)", "legendFormat": "AI Defense", "refId": "D"}
      ],
      "title": "차단 사유별 추이 (ext_authz)", "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never"}, "unit": "reqps"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "403"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "429"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5}, "id": 7,
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum(rate(istio_requests_total{reporter=\"destination\", response_code=\"403\"}[5m])) or vector(0)", "legendFormat": "403", "refId": "A"},
        {"expr": "sum(rate(istio_requests_total{reporter=\"destination\", response_code=\"429\"}[5m])) or vector(0)", "legendFormat": "429", "refId": "B"}
      ],
      "title": "Istio 403/429 추이", "type": "timeseries"
    },
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13}, "id": 10, "title": "차단 상세", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14}, "id": 11,
      "options": {"legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"]}, "pieType": "donut", "reduceOptions": {"calcs": ["lastNotNull"]}, "tooltip": {"mode": "single"}},
      "targets": [{"expr": "sum by (reason) (increase(authz_adapter_check_requests_total{action=\"block\"}[$__range]))", "legendFormat": "{{reason}}", "refId": "A"}],
      "title": "차단 사유 분포", "type": "piechart"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14}, "id": 12,
      "options": {"legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"]}, "pieType": "donut", "reduceOptions": {"calcs": ["lastNotNull"]}, "tooltip": {"mode": "single"}},
      "targets": [{"expr": "topk(10, sum by (path) (increase(authz_adapter_check_requests_total{action=\"block\"}[$__range])))", "legendFormat": "{{path}}", "refId": "A"}],
      "title": "차단 경로 분포", "type": "piechart"
    },
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22}, "id": 20, "title": "차단 로그", "type": "row"},
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 23}, "id": 21,
      "options": {"dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true},
      "targets": [{"datasource": {"type": "loki", "uid": "loki"}, "expr": "{namespace=~\"staging-ai\"} |~ `block|blacklist|blocked` | json | line_format \"[{{.level}}] {{.client_ip}} | {{.msg}} | path={{.path}} | reason={{.reason}}\"", "refId": "A"}],
      "title": "보안 차단 로그 (authz-adapter)", "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["security", "alert", "staging"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "2. 보안 알람 현황",
  "uid": "security-alert-overview",
  "version": 3
}
