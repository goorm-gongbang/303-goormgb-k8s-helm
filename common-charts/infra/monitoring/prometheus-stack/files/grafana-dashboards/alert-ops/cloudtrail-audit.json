      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1}, "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
        "queryMode": "Logs",
        "logGroups": [{"arn": "arn:aws:logs:ap-northeast-2:406223549139:log-group:/aws/cloudtrail/playball/audit:*"}],
        "expression": "filter eventName = 'ConsoleLogin' | stats count(*) as logins",
        "refId": "A"
      }],
      "title": "콘솔 로그인", "type": "stat"
