      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "id": 12,
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
        "queryMode": "Logs",
        "logGroups": [{"arn": "arn:aws:logs:ap-northeast-2:406223549139:log-group:/aws/cloudtrail/playball/audit:*"}],
        "expression": "filter errorCode like /Unauthorized|AccessDenied|Forbidden|Denied/ | stats count(*) as denied by bin(5m)",
        "refId": "A"
      }],
      "title": "권한 거부 추이", "type": "timeseries"
