        "queryMode": "Logs",
        "logGroups": [{"arn": "arn:aws:logs:ap-northeast-2:406223549139:log-group:/aws/cloudtrail/playball/audit:*"}],
        "expression": "filter errorCode like /Unauthorized|AccessDenied|Forbidden/ | stats count(*) as cnt by eventName, errorCode, userIdentity.arn, sourceIPAddress | sort cnt desc | limit 20",
        "refId": "A"
      }],
      "title": "권한 거부 상세 (Top 20)", "type": "table"
    },
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25}, "id": 30, "title": "서비스별 분석", "type": "row"},
    {
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
