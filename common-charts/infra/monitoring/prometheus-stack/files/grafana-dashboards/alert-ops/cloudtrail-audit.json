  "panels": [
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 1, "title": "API 활동 요약", "type": "row"},
    {
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1}, "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
        "queryMode": "Logs",
        "logGroups": [{"arn": "arn:aws:logs:ap-northeast-2:406223549139:log-group:/aws/cloudtrail/playball/audit:*"}],
        "expression": "fields @timestamp | stats count(*) as total",
        "refId": "A"
      }],
      "title": "총 API 호출", "type": "stat"
    },
    {
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1}, "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
        "queryMode": "Logs",
        "logGroups": [{"arn": "arn:aws:logs:ap-northeast-2:406223549139:log-group:/aws/cloudtrail/playball/audit:*"}],
        "expression": "filter errorCode like /Unauthorized|AccessDenied|Forbidden/ | stats count(*) as denied",
        "refId": "A"
      }],
      "title": "권한 거부 (AccessDenied)", "type": "stat"
    },
    {
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
