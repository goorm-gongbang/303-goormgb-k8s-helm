          {"matcher": {"id": "byName", "options": "sourceIPAddress"}, "properties": [{"id": "custom.width", "value": 130}]},
          {"matcher": {"id": "byName", "options": "errorCode"}, "properties": [{"id": "custom.width", "value": 120}, {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 20, "w": 24, "x": 0, "y": 35}, "id": 41,
      "options": {"cellHeight": "sm", "showHeader": true, "sortBy": [{"desc": true, "displayName": "@timestamp"}], "footer": {"show": false}},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
        "queryMode": "Logs",
        "logGroups": [{"arn": "arn:aws:logs:ap-northeast-2:406223549139:log-group:/aws/cloudtrail/playball/audit:*"}],
        "expression": "fields @timestamp, eventName, eventSource, userIdentity.arn, sourceIPAddress, errorCode | sort @timestamp desc | limit 200",
