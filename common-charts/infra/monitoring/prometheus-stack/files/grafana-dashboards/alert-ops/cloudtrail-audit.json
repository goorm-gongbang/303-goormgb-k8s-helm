    },
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34}, "id": 40, "title": "Raw 로그", "type": "row"},
    {
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "description": "CloudTrail 원본 로그 - 시간, 이벤트, 서비스, 수정 주체, IP, 에러",
