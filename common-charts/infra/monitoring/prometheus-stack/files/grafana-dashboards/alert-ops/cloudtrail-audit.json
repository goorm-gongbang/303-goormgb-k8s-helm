      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "description": "IAM, SG, 정책 변경 등 보안 관련 API 호출",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "cnt"}, "properties": [{"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "gauge"}}, {"id": "min", "value": 0}]}
