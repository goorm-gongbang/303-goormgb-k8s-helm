        {"expr": "sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\", http_response_status_code=~\"4..\"}[$__rate_interval]))", "legendFormat": "4xx", "refId": "B"},
        {"expr": "sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\", http_response_status_code=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx", "refId": "C"}
