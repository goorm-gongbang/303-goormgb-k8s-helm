        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": true,
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\"}[$__rate_interval]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "title": "초당 요청 수 (RPS)",
      "type": "stat"
