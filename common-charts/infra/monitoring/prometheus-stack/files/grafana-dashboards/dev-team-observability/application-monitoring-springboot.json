        {"expr": "100 * sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\", http_response_status_code=~\"4..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\"}[$__rate_interval])), 1)", "legendFormat": "4xx 에러율", "refId": "B"}
      ],
