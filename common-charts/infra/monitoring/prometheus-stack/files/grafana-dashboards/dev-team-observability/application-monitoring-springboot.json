      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "응답 시간 백분위수 추이입니다. P50(중앙값), P95, P99를 함께 비교합니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "line"}
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "P50"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "P95"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "P99"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 20,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{namespace=~\"$namespace\", app=~\"$app_name\"}[$__rate_interval])))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{namespace=~\"$namespace\", app=~\"$app_name\"}[$__rate_interval])))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{namespace=~\"$namespace\", app=~\"$app_name\"}[$__rate_interval])))", "legendFormat": "P99", "refId": "C"}
      ],
      "title": "응답시간 백분위수 (P50/P95/P99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "경로별 평균 응답 시간입니다. 느린 API 엔드포인트를 식별합니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-GrYlRd"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.3},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 21,
      "options": {
        "displayMode": "lcd",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (http_route) (rate(http_server_request_duration_seconds_sum{namespace=~\"$namespace\", app=~\"$app_name\", http_route!~\"/actuator.*|/swagger.*|/v3/api-docs.*|NOT_FOUND|UNKNOWN|/health.*|/ready.*|/metrics.*\"}[$__rate_interval])) / clamp_min(sum by (http_route) (rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\", http_route!~\"/actuator.*|/swagger.*|/v3/api-docs.*|NOT_FOUND|UNKNOWN|/health.*|/ready.*|/metrics.*\"}[$__rate_interval])), 1))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "title": "느린 엔드포인트 TOP 10",
      "type": "bargauge"
    },
    {
      "collapsed": false,
