    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "선택 기간 동안 처리한 전체 HTTP 요청 수입니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": true,
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\"}[$__range]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "총 요청 수",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
