        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{namespace=~\"$namespace\", app=~\"$app_name\", http_response_status_code=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "TPS (2xx)",
          "refId": "B"
        }
      ],
      "title": "RPS / TPS 추이",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "HTTP 상태코드별 요청 추이입니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
