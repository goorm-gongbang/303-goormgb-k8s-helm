    {
      "datasource": "Prometheus",
      "description": "전체 요청 중 에러(4xx+5xx) 비율입니다.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 11,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "100 * sum(increase(http_server_request_duration_seconds_count{job=~\"${app_name:regex}\", http_response_status_code=~\"[45]..\"}[$__range])) / clamp_min(sum(increase(http_server_request_duration_seconds_count{job=~\"${app_name:regex}\"}[$__range])), 1)",
          "legendFormat": "에러율",
          "refId": "A"
        }
      ],
      "title": "에러율 (%)",
      "type": "stat"
    },
