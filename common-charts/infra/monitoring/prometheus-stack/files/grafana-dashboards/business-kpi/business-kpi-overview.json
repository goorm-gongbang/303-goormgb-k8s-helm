    {
      "datasource": "Prometheus",
      "description": "선택한 기간 동안 Hold 시도 총건수입니다. 전체 좌석 선점 수요의 분모로 사용합니다.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
