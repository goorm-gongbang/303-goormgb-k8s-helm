{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Envoy ext_authz에서 authz-adapter로 들어오는 인증 검사 요청의 초당 처리량입니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_handled_total{grpc_service=\"envoy.service.auth.v3.Authorization\", namespace=\"$namespace\"}[1m])) by (grpc_code)",
          "legendFormat": "{{grpc_code}}",
          "refId": "A"
        }
      ],
      "title": "인증 검사 요청량 (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "인증 검사 요청의 응답 지연시간입니다. p95, p99 백분위수를 표시합니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "ms"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["mean", "p95", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(grpc_server_handling_seconds_bucket{grpc_service=\"envoy.service.auth.v3.Authorization\", namespace=\"$namespace\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 지연시간",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(grpc_server_handling_seconds_bucket{grpc_service=\"envoy.service.auth.v3.Authorization\", namespace=\"$namespace\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99 지연시간",
          "refId": "B"
        }
      ],
      "title": "인증 검사 지연시간 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "인증 검사 요청 중 성공(OK)한 비율입니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.95},
              {"color": "green", "value": 0.99}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_handled_total{grpc_service=\"envoy.service.auth.v3.Authorization\", grpc_code=\"OK\", namespace=\"$namespace\"}[5m])) / sum(rate(grpc_server_handled_total{grpc_service=\"envoy.service.auth.v3.Authorization\", namespace=\"$namespace\"}[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "성공률",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "현재 실행 중인 authz-adapter 인스턴스 수입니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 8},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(up{job=~\".*authz-adapter.*\", namespace=\"$namespace\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "실행 인스턴스",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "AI Defense API 호출의 초당 처리량입니다. 상태별로 구분됩니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 5,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "sum(rate(authz_adapter_ai_defense_requests_total{namespace=\"$namespace\"}[1m])) by (status)",
          "legendFormat": "AI Defense {{status}}",
          "refId": "A"
        }
      ],
      "title": "AI Defense API 호출량",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "AI Defense API 호출의 응답 지연시간입니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "ms"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 6,
      "options": {
        "legend": {"calcs": ["mean", "p95", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(authz_adapter_ai_defense_duration_seconds_bucket{namespace=\"$namespace\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "AI Defense API 지연시간 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "description": "authz-adapter 서비스의 실시간 로그입니다.",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{namespace=\"$namespace\", app=\"authz-adapter\", container!=\"istio-proxy\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "authz-adapter 로그",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ai", "authz", "ext_authz", "security"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "prometheus"},
        "hide": 0,
        "includeAll": false,
        "label": "데이터소스",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "네임스페이스",
        "multi": false,
        "name": "namespace",
        "options": [
          {"selected": true, "text": "__AI_NAMESPACE__", "value": "__AI_NAMESPACE__"}
        ],
        "query": "__AI_NAMESPACE__",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "[AI] 인증 어댑터 모니터링",
  "uid": "authz-adapter-monitoring",
  "version": 1
}
