        "query": "__AI_NAMESPACE__",
        "type": "custom"
      },
      {
        "allValue": ".*",
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]},
        "hide": 0,
        "includeAll": true,
        "label": "Pod",
        "multi": true,
        "name": "pod",
        "options": [
          {"selected": false, "text": "ai-defense", "value": ".*ai-defense.*"},
          {"selected": false, "text": "authz-adapter", "value": ".*authz-adapter.*"}
        ],
        "query": ".*ai-defense.*,.*authz-adapter.*",
        "type": "custom"
      },
      {
        "allValue": ".*",
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "hide": 0,
        "includeAll": true,
        "label": "로그 레벨",
        "multi": false,
        "name": "level",
        "options": [
          {"selected": false, "text": "ERROR", "value": "ERROR|error"},
          {"selected": false, "text": "WARN", "value": "WARN|warn|WARNING"},
          {"selected": false, "text": "INFO", "value": "INFO|info"},
          {"selected": false, "text": "DEBUG", "value": "DEBUG|debug"}
        ],
        "query": "ERROR|error,WARN|warn|WARNING,INFO|info,DEBUG|debug",
        "type": "custom"
      },
      {
        "current": {"selected": false, "text": "", "value": ""},
        "hide": 0,
        "label": "검색어",
        "name": "query",
        "options": [{"selected": true, "text": "", "value": ""}],
        "query": "",
        "type": "textbox"
      },
      {
        "current": {"selected": true, "text": "Health/Metrics/OTEL 제외", "value": "!~ \"/healthz|/readyz|/livez|/health|/ready|/metrics|/actuator|TraceService/Export|MetricsService/Export\""},
        "hide": 0,
        "includeAll": false,
        "label": "필터",
        "multi": false,
        "name": "healthFilter",
        "options": [
          {"selected": true, "text": "Health/Metrics/OTEL 제외", "value": "!~ \"/healthz|/readyz|/livez|/health|/ready|/metrics|/actuator|TraceService/Export|MetricsService/Export\""},
          {"selected": false, "text": "Health만 제외", "value": "!~ \"/healthz|/readyz|/livez|/health|/ready\""},
          {"selected": false, "text": "ERROR만 보기", "value": "|~ \"ERROR|error|Error\""},
          {"selected": false, "text": "전체 보기", "value": "|~ \".*\""}
        ],
        "query": "",
        "type": "custom"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
