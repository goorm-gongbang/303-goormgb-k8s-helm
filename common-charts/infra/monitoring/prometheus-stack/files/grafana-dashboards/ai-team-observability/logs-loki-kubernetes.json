        "query": "__AI_NAMESPACE__",
        "type": "custom"
      },
      {
        "allValue": ".*",
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]},
        "hide": 0,
        "includeAll": true,
        "label": "Pod",
        "multi": true,
        "name": "pod",
        "options": [
          {"selected": false, "text": "ai-defense", "value": ".*ai-defense.*"},
          {"selected": false, "text": "authz-adapter", "value": ".*authz-adapter.*"}
        ],
        "query": ".*ai-defense.*,.*authz-adapter.*",
        "type": "custom"
      },
      {
        "current": {"selected": true, "text": "전체", "value": "|= ``"},
        "hide": 0,
        "includeAll": false,
        "label": "필터",
        "multi": false,
        "name": "healthFilter",
        "options": [
          {"selected": true, "text": "전체", "value": "|= ``"},
          {"selected": false, "text": "Health/Metrics 제외", "value": "!~ `/healthz|/readyz|/livez|/health|/ready|/metrics|/actuator`"},
          {"selected": false, "text": "ERROR만 보기", "value": "|~ `ERROR|error`"},
          {"selected": false, "text": "WARN 이상", "value": "|~ `ERROR|error|WARN|warn|WARNING`"}
        ],
        "query": "",
        "type": "custom"
      },
      {
        "current": {"selected": true, "text": "전체", "value": ""},
        "hide": 0,
        "includeAll": false,
        "label": "쿼리 타입",
        "multi": false,
        "name": "queryType",
        "options": [
          {"selected": true, "text": "전체", "value": ""},
          {"selected": false, "text": "DB 쿼리", "value": "|~ `(?i)(select|insert|update|delete|query|sql|database|postgres|clickhouse|execute)`"},
          {"selected": false, "text": "서비스 쿼리", "value": "|~ `(?i)(http|request|response|endpoint|api|handler|grpc|evaluate|telemetry|challenge)`"},
          {"selected": false, "text": "Istio 쿼리", "value": "|~ `(?i)(istio|envoy|upstream|downstream|xds|pilot|proxy|ext_authz)`"}
        ],
        "query": "",
        "type": "custom"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "[AI] 로그 확인",
