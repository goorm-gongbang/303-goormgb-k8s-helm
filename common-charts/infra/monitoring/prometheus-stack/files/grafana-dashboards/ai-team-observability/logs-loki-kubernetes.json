  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "description": "시간대별 로그 발생 건수입니다.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "bars",
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "none"}
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        }
      },
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 0},
      "id": 4,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum by (app) (count_over_time({namespace=\"__AI_NAMESPACE__\", app=~\"$app\"} |~ \"$query\" [$__interval]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "title": "로그 건수 추이",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "description": "AI 서비스 로그 스트림",
      "gridPos": {"h": 25, "w": 24, "x": 0, "y": 5},
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "editorMode": "code",
          "expr": "{namespace=\"__AI_NAMESPACE__\", app=~\"$app\", container!=\"istio-proxy\"} |~ \"$level\" |~ \"$query\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "로그 스트림",
      "type": "logs"
    }
  ],
  "refresh": "30s",
