            "uid": "prometheus"
          },
          "expr": "sum by (service, pod) (hikaricp_connections_pending{service=~\"api-gateway|auth-guard|queue|seat|order-core\"})",
          "legendFormat": "{{service}} pending [{{pod}}]"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service, pod) (hikaricp_connections_max{service=~\"api-gateway|auth-guard|queue|seat|order-core\"})",
          "legendFormat": "{{service}} max [{{pod}}]"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "loadtest-webs 전체 로그 보기",
              "url": "/explore?left={\"datasource\":\"loki\",\"queries\":[{\"refId\":\"A\",\"expr\":\"{namespace=\\\"loadtest-webs\\\"} |~ \\\"(?i)(ERROR|WARN|Exception|503)\\\"\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": true
            }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Tomcat 스레드 사용량",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "**Tomcat (임베디드) 스레드 사용량**\n\n- `current` : 현재 생성된 워커 스레드\n- `busy` : 요청 처리 중인 스레드\n- `max` : 상한 (기본 200)\n\n---\n**읽는 법**\n- `busy ≈ max` : 스레드 풀 고갈. 새 요청이 OS 레벨에서 queue 대기 중 → latency 폭증.\n\n**조치**\n- `server.tomcat.threads.max` 상향 (예: 200 → 400)\n- 동시에 CPU/메모리 부담 상승 주의 → HPA 같이 검토\n",
      "targets": [
        {
          "expr": "sum by (service, pod) (jvm_threads_live_threads{service=~\"api-gateway|auth-guard|queue|seat|order-core\"})",
          "legendFormat": "{{service}} live [{{pod}}]",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum by (service, pod, state) (jvm_threads_states_threads{service=~\"api-gateway|auth-guard|queue|seat|order-core\", state=\"runnable\"})",
          "legendFormat": "{{service}} runnable [{{pod}}]",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum by (service, pod) (jvm_threads_peak_threads{service=~\"api-gateway|auth-guard|queue|seat|order-core\"})",
          "legendFormat": "{{service}} peak [{{pod}}]",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "loadtest-webs 전체 로그 보기",
              "url": "/explore?left={\"datasource\":\"loki\",\"queries\":[{\"refId\":\"A\",\"expr\":\"{namespace=\\\"loadtest-webs\\\"} |~ \\\"(?i)(ERROR|WARN|Exception|503)\\\"\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
