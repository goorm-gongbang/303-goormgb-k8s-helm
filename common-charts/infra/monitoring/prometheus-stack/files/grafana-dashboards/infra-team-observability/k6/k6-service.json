        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(k6_http_reqs_total{name=~\"$service\", expected_response=\"false\"}[1m]))", "legendFormat": "Failed", "refId": "B" }
      ],
      "title": "Request Rate",
      "type": "timeseries"
