      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(k6_http_req_duration_min{name=~\"$service\"}) * 1000", "legendFormat": "Min", "refId": "E" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(k6_http_req_duration_avg{name=~\"$service\"}) * 1000", "legendFormat": "Avg", "refId": "A" },
