      { "allValue": ".*", "current": {}, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "definition": "label_values(k6_http_reqs_total, name)", "hide": 0, "includeAll": true, "label": "Service", "multi": true, "name": "service", "options": [], "query": { "query": "label_values(k6_http_reqs_total, name)", "refId": "PrometheusVariableQueryEditor-VariableQuery" }, "refresh": 2, "regex": "", "skipUrlSync": false, "sort": 1, "type": "query" }
    ]
