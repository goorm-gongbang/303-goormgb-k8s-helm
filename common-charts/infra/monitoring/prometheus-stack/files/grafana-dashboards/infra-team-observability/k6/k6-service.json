        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(k6_http_req_duration_p95{name=~\"$service\"}) * 1000", "legendFormat": "P95", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(k6_http_req_duration_p99{name=~\"$service\"}) * 1000", "legendFormat": "P99", "refId": "D" }
