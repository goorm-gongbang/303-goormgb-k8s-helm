      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(pg_stat_database_xact_commit{namespace=\"data\"}[$__rate_interval]))", "legendFormat": "Commit", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(pg_stat_database_xact_rollback{namespace=\"data\"}[$__rate_interval]))", "legendFormat": "Rollback", "refId": "B" }
