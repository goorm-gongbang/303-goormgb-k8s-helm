      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "topk(10, sum by (http_route) (rate(http_server_request_duration_seconds_sum{namespace=\"$namespace\", app=~\"$app\", http_route=~\"/.+\", http_route!~\".*actuator.*|.*swagger.*|.*api-docs.*|.*health.*|.*ready.*|.*metrics.*\"}[$__rate_interval])) / clamp_min(sum by (http_route) (rate(http_server_request_duration_seconds_count{namespace=\"$namespace\", app=~\"$app\", http_route=~\"/.+\", http_route!~\".*actuator.*|.*swagger.*|.*api-docs.*|.*health.*|.*ready.*|.*metrics.*\"}[$__rate_interval])), 1) * 1000)", "legendFormat": "{{http_route}}", "refId": "A" }],
      "title": "느린 엔드포인트 TOP 10",
      "type": "bargauge"
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 104, "panels": [], "title": "PostgreSQL (Pod)", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "PostgreSQL 활성 연결 수",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] }, "unit": "short" },
        "overrides": []
