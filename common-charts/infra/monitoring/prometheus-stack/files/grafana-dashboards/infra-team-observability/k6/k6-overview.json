  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["k6", "load-testing", "performance"],
  "templating": {
    "list": [
      { "current": { "selected": false, "text": "Prometheus", "value": "prometheus" }, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "regex": "", "skipUrlSync": false, "type": "datasource" }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "k6 Load Test - Overview",
  "uid": "k6-overview",
  "version": 1
