      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(cilium_endpoint_state{state=\"ready\"})",
          "legendFormat": "Ready Endpoints",
          "refId": "A"
        }
      ],
      "title": "Ready Endpoints",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
